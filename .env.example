# === Required ===
LLM_API_KEY=your_perplexity_api_key_here
TARGET_BASE_URL=https://example-target-site.com/entity

# === Optional: File names ===
INPUT_FILENAME=input_data.xlsx
OUTPUT_FILENAME=enriched_data.xlsx

# === Optional: Column names in your Excel file ===
COL_ENTITY_NAME=name
COL_LOCATION=location

# === Optional: Keyword to locate the metric on the page ===
SEARCH_KEYWORD=Rating

# === Optional: For data_verified.py — regex patterns to extract data ===
# PATTERN_MAIN_TEXT=
# PATTERN_METRIC=

# === Optional: LLM API base URL (defaults to Perplexity) ===
LLM_API_BASE=https://api.perplexity.ai
